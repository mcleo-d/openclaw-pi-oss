# OpenClaw environment template — copy to .env and fill in values before deploying.
# chmod 600 .env after creating it.

# Docker image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Directories — update <username> to your Pi username
OPENCLAW_CONFIG_DIR=/home/<username>/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/<username>/.openclaw/workspace

# Ports
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Gateway auth token — generate a strong random value, e.g.:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=<your-gateway-token>

# Claude API credentials — not required when using Ollama. Populate if switching to Claude.
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
